{
  "name": "kairos-ipc-prototype",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/chromatix",
    "packages/chromatix-vue",
    "packages/chromatix-unocss"
  ],
  "scripts": {
    "kernel": "$BUN_INSTALL/bin/bun packages/kernel/src/main.ts",
    "demo:echo": "$BUN_INSTALL/bin/bun examples/echo-demo.ts",
    "demo:pipeline": "$BUN_INSTALL/bin/bun examples/pipeline-demo.ts",
    "demo:slock-basic": "$BUN_INSTALL/bin/bun examples/slock-basic-demo.ts",
    "demo:slock-agent-adapter": "$BUN_INSTALL/bin/bun examples/slock-agent-adapter-demo.ts",
    "demo:slock-pi-faux": "$BUN_INSTALL/bin/bun examples/slock-pi-faux-demo.ts",
    "demo:slock-web": "$BUN_INSTALL/bin/bun run build:slock-ui && $BUN_INSTALL/bin/bun examples/slock-web-demo.ts",
    "demo:dify-bridge": "$BUN_INSTALL/bin/bun examples/dify-bridge-demo.ts",
    "demo:mattermost-bridge": "$BUN_INSTALL/bin/bun examples/mattermost-bridge-demo.ts",
    "dev:slock-ui": "vite --config packages/slock-ui-bridge/vite.config.ts",
    "dev:kairos-desk-ui": "vite --config packages/kairos-desk-ui/vite.config.ts",
    "typecheck:slock-ui": "vue-tsc -p packages/slock-ui-bridge/tsconfig.web.json --noEmit",
    "typecheck:kairos-desk-ui": "vue-tsc -p packages/kairos-desk-ui/tsconfig.web.json --noEmit",
    "build:slock-ui": "vue-tsc -p packages/slock-ui-bridge/tsconfig.web.json --noEmit && vite build --config packages/slock-ui-bridge/vite.config.ts",
    "build:kairos-desk-ui": "vue-tsc -p packages/kairos-desk-ui/tsconfig.web.json --noEmit && vite build --config packages/kairos-desk-ui/vite.config.ts",
    "test:kairos-desk-ui": "${BUN_INSTALL:-$HOME/.bun}/bin/bun test packages/kairos-desk-ui/web/src/**/*.test.ts",
    "test": "${BUN_INSTALL:-$HOME/.bun}/bin/bun test tests/*.test.ts packages/kairos-desk-ui/web/src/**/*.test.ts"
  },
  "engines": {
    "bun": ">=1.3.13"
  },
  "dependencies": {
    "@kairos-ipc/chromatix": "workspace:*",
    "@kairos-ipc/chromatix-vue": "workspace:*",
    "@kairos-ipc/unocss-preset-chromatix": "workspace:*",
    "@mariozechner/pi-ai": "^0.70.6",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "culori": "^4.0.2",
    "lucide-vue-next": "^1.0.0",
    "postcss-value-parser": "^4.2.0",
    "reka-ui": "^2.9.6",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "unified": "^11.0.5",
    "vue": "^3.5.33",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/bun": "^1.3.13",
    "@types/culori": "^4.0.1",
    "@unocss/core": "^66.5.10",
    "@vitejs/plugin-vue": "^6.0.6",
    "shadcn-vue": "^2.6.2",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vue-tsc": "^3.2.7"
  }
}
