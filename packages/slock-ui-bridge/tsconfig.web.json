{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "paths": {
      "@/*": ["./web/src/*"],
      "@kairos-ipc/chromatix": ["../chromatix/src/index.ts"],
      "@kairos-ipc/chromatix-vue": ["../chromatix-vue/src/index.ts"],
      "@kairos-ipc/unocss-preset-chromatix": ["../chromatix-unocss/src/index.ts"]
    },
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "jsx": "preserve",
    "types": ["vite/client"]
  },
  "include": ["web/env.d.ts", "web/src/**/*.ts", "web/src/**/*.vue"]
}
